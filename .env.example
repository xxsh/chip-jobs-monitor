# Example environment for chip-jobs-monitor.
#
# The pipeline reads plain environment variables — it does NOT auto-load a .env file.
# Copy this to `.env`, edit it, and `source .env` before running, or copy the lines
# you need into your cron/launchd wrapper (see run-daily.sh).

# --- Resume (required for scoring) ---------------------------------------------
# Path to your resume markdown, relative to this repo dir. Generate the profile
# cache once after setting this (see README "Profile cache").
export RESUME_PATH="../resume.md"

# --- Which companies to monitor -----------------------------------------------
# Default = nvidia + every adapter in sources/ (amd, arm, intel). Comma-separated.
# export MONITOR_SOURCES="nvidia,amd,arm,intel"
# Score a brand-new source's whole existing backlog once (onboarding only):
# export SEED_SOURCES="amd"

# --- NVIDIA scraper (Playwright) ----------------------------------------------
export NVIDIA_LOCATION="Shanghai, China"
# Override only if you must point at a specific chromium/headless-shell binary;
# by default Playwright's bundled chromium is used (`playwright install chromium`).
# export NVIDIA_CHROMIUM_PATH=""
# export NVIDIA_MAX_JOBS=""              # cap listings (testing)
# export NVIDIA_DETAIL_CONCURRENCY="6"
# export NVIDIA_SKIP_FETCH="1"           # re-render/score from existing snapshots only

# --- Scorer (codex CLI) tuning ------------------------------------------------
# export NVIDIA_SCORER_CONCURRENCY="3"          # <= 3
# export NVIDIA_MAX_SCORING_JOBS_PER_RUN="3"
# export NVIDIA_SCORER_JOB_TIMEOUT_SECONDS="90"
# export NVIDIA_SCORER_ATTEMPTS="1"
# export SCORER_PYTHON="scorer/.venv/bin/python"

# --- MySQL persistence (optional) ---------------------------------------------
# If unset, the run still works and just skips persistence.
# export MYSQL_USER="root"
# export MYSQL_SOCKET_PATH="/tmp/mysql.sock"
# export MYSQL_DATABASE="chip_jobs_monitor"
# export MYSQL_HOST="localhost"
# export MYSQL_PASSWORD=""
# Or a single DSN instead of the parts above:
# export MYSQL_DSN="mysql://user:pass@host:3306/chip_jobs_monitor"
